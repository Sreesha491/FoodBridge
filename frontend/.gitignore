# Node.js / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite build output
dist/
dist-ssr/
*.local

# Environment / Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor – VS Code
.vscode/
!.vscode/extensions.json

# Editor – WebStorm / IntelliJ
.idea/
*.iml

# OS-generated
.DS_Store
Thumbs.db

# Storybook (if added later)
storybook-static/

# Testing
coverage/
