.idea/
*.iml
*.iws
*.ipr
out/

# IDE – VS Code
.vscode/
*.code-workspace

# IDE – Eclipse
.classpath
.project
.settings/
*.launch

# IDE – NetBeans
nbproject/
build/
nbbuild/
dist/
nbdist/
.nb-gradle/

# Logs
logs/
*.log
*.log.*

# Temporary files
tmp/
temp/
