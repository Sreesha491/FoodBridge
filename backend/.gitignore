# ──────────────────────────────────────────────
#  FoodBridge Backend – .gitignore
# ──────────────────────────────────────────────

# Maven build outputs
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Maven Wrapper
.mvn/wrapper/maven-wrapper.properties

# IDE – IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# IDE – VS Code
.vscode/

# IDE – Eclipse
.classpath
.project
.settings/
*.launch

# Spring Boot DevTools restart files
.reloadtrigger
spring-devtools-trigger.txt

# Environment / Secrets
.env
*.env
application-local.yml
application-secret.yml

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
